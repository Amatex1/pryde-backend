# Backend Environment Variables
# Copy this file to .env and fill in your actual values

# Server Configuration
NODE_ENV=production
PORT=10000

# Database
# MongoDB connection string (required)
# Get this from MongoDB Atlas or your MongoDB provider
MONGO_URL=mongodb+srv://username:password@cluster.mongodb.net/pryde-social?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/pryde-social?retryWrites=true&w=majority

# JWT Secret (required)
# Generate a strong random string for production
# You can use: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Refresh Token Secret (required in production)
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-this

# CSRF Secret (required in production)
CSRF_SECRET=your-csrf-secret-change-this

# ─── PII / Message Encryption ───────────────────────────────────────────────
# REQUIRED in production. Must be a 64-character hex string (32 bytes).
# Used for AES-256-GCM encryption of: messages, 2FA secrets, birthday,
# pronouns, sexualOrientation, and gender fields at rest.
#
# Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#
# WARNING: Changing this key WILL make existing encrypted data unreadable.
# Store securely (e.g. in a secrets manager, not in version control).
MESSAGE_ENCRYPTION_KEY=generate-a-64-char-hex-key-before-deploying-to-production-00000

# URLs
# Your backend URL (Render will provide this)
BASE_URL=https://your-app-name.onrender.com

# Your frontend URL (your SiteGround domain)
FRONTEND_URL=https://prydeapp.com

# Custom API domain used by the frontend in production for auth/socket requests
# Use the FULL URL here
API_DOMAIN=https://api.prydeapp.com

# Root domain for refresh-token cookie sharing across prydeapp.com + api.prydeapp.com
# IMPORTANT: use the BARE apex domain only — no protocol, no path, no port
ROOT_DOMAIN=prydeapp.com

# Web Push Notifications (optional)
# Generate VAPID keys with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key

# Firebase Cloud Messaging (FCM) — Native Android/iOS push notifications
# Option 1: Paste the full Firebase service account JSON as a string (recommended for cloud)
FIREBASE_SERVICE_ACCOUNT_JSON=
# Option 2: Path to Firebase service account JSON file (for local dev)
FIREBASE_SERVICE_ACCOUNT_PATH=

# Passkey/WebAuthn Configuration (required for passkey authentication)
# RP_ID should be your backend domain (without https://)
RP_ID=pryde-social.onrender.com
# ORIGIN should be your frontend URL (with https://)
ORIGIN=https://prydeapp.com

# Email Configuration (required for password reset emails)
# Using Resend for transactional emails
# Get your API key from: https://resend.com/api-keys
RESEND_API_KEY=re_your_api_key_here
EMAIL_FROM=Pryde Social <noreply@prydeapp.com>

# hCaptcha Configuration (optional but recommended for production)
# Get your keys from: https://www.hcaptcha.com/
# Secret key is used for server-side verification
# For testing, use: 0x0000000000000000000000000000000000000000 (always passes)
HCAPTCHA_SECRET=0x0000000000000000000000000000000000000000

# App Version (auto-incremented on deploy)
# Format: YYYY-MM-DD-XXX (e.g., 2025-01-22-001)
APP_VERSION=1.0.0

# Build Time (auto-set during build)
BUILD_TIME=2025-01-22T00:00:00.000Z

# Automatic Backups (optional)
# Set to 'true' to enable automatic daily database backups
# Schedule: Once per day at 3:00 AM UTC
# Retention: 30 days (~30 backups, ~23 MB total)
# For manual backups, use: npm run backup
ENABLE_AUTO_BACKUP=false

# Backup API Key (REQUIRED if ENABLE_AUTO_BACKUP=true or backup routes are mounted)
# Generate a strong random value: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Never use the default — the server will refuse to start in production without this set
BACKUP_API_KEY=CHANGE_THIS_TO_A_STRONG_RANDOM_VALUE

# Backup Webhook (optional)
# Discord/Slack webhook URL to receive backup notifications
# BACKUP_WEBHOOK_URL=https://discord.com/api/webhooks/your-webhook-url

# Redis Feed Caching (optional — falls back to in-memory)
# Get from Redis Cloud, Upstash, or self-hosted
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# ─── Security Alerts ────────────────────────────────────────────────────────
# Email address to receive real-time security alerts (optional but recommended)
# Alerts fire for: refresh token reuse, brute-force spikes, malware detections, etc.
SECURITY_ALERT_EMAIL=security@prydeapp.com
# Set to 'false' to disable all alerts without removing the config
SECURITY_ALERTS_ENABLED=true
# Event count thresholds (events within 15-min window trigger an alert)
# ALERT_THRESH_ADMIN_FAIL=3
# ALERT_THRESH_BRUTE_FORCE=20
# ALERT_THRESH_BULK_BAN=5
# ALERT_THRESH_UNDERAGE=3
# ALERT_THRESH_ADMIN_2FA=3

# ─── Session Idle Timeout ────────────────────────────────────────────────────
# DB-backed idle timeout in milliseconds (default: 1800000 = 30 minutes)
# Set to 0 to disable idle timeout (relying on refresh token TTL only)
# SESSION_IDLE_TIMEOUT_MS=1800000

# ─── Refresh Token Family Revocation ─────────────────────────────────────────
# When a reused refresh token is detected, ALL active sessions for the user are
# revoked immediately (session family revocation). This protects against token
# theft even when you don't know which session was compromised. The user will be
# required to log in again on all devices.
# This behavior is always-on and cannot be disabled.

# ─── File Malware Scanning ───────────────────────────────────────────────────
# Provider: none | clamav | virustotal
# "none" skips scanning with a warning in production
# PRODUCTION RECOMMENDATION: set FILE_SCAN_PROVIDER=clamav or virustotal
# and FILE_SCAN_REJECT_ON_UNAVAILABLE=true (fail-closed posture)
FILE_SCAN_PROVIDER=none
# Set to 'true' to REJECT uploads when scanner is unavailable (fail-closed)
# In production, strongly recommended to set this to 'true'
FILE_SCAN_REJECT_ON_UNAVAILABLE=false
# ClamAV (if FILE_SCAN_PROVIDER=clamav)
# CLAMAV_HOST=127.0.0.1
# CLAMAV_PORT=3310
# VirusTotal (if FILE_SCAN_PROVIDER=virustotal)
# VIRUSTOTAL_API_KEY=your-virustotal-api-key

# ─── API Documentation ───────────────────────────────────────────────────────
# Swagger UI is DISABLED in production by default.
# Set to 'true' only in staging/internal envs — never in public production.
# ENABLE_SWAGGER_DOCS=false

# Cloudflare R2 Storage
# Get from: https://dash.cloudflare.com/ → R2
R2_ENABLED=true
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=pryde-media
# CDN / public bucket URL (set this to enable CDN delivery)
# 1. In Cloudflare R2: enable "Public Access" or add a custom domain
# 2. In Cloudflare DNS: CNAME media.prydeapp.com → <bucket>.r2.cloudflarestorage.com
# 3. Set this to your CDN domain (must match VITE_CDN_URL in frontend .env)
R2_PUBLIC_URL=https://media.prydeapp.com

# ─── PII Field Encryption — Migration Notes ──────────────────────────────────
# After setting MESSAGE_ENCRYPTION_KEY for the first time on an existing database,
# run the PII backfill script to encrypt any existing plaintext records:
#
#   # Preview (dry run):
#   npm run backfill:pii
#
#   # Apply:
#   npm run backfill:pii:apply
#
# The app works without running this script (lazy migration on next save),
# but running it ensures all records are encrypted immediately.
