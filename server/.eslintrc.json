{
  "env": {
    "node": true,
    "es2022": true,
    "mocha": true
  },
  "extends": "eslint:recommended",
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "module"
  },
  "rules": {
    "no-console": "off",
    "no-unused-vars": ["warn", { "argsIgnorePattern": "^_" }],
    "no-process-exit": "off"
  },
  "ignorePatterns": ["node_modules/", "test/", "*.test.js"]
}
