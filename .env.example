
# Pryde Social Backend - Environment Template
# Copy to .env and fill in your values

# Database
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/pryde-social?retryWrites=true&w=majority
MONGO_URL=$MONGODB_URI

# Redis (Render Upstash Free Tier)
REDIS_URL=redis://default:password@host:port

# JWT (Generate with openssl rand -hex 64)
JWT_SECRET=your-64-char-secret-here
JWT_REFRESH_SECRET=your-64-char-different-secret

# CSRF (Generate with openssl rand -hex 32)
CSRF_SECRET=your-csrf-secret-here

# Security
MESSAGE_ENCRYPTION_KEY=your-32-char-encryption-key

# Push Notifications
VAPID_PUBLIC_KEY=your-public-vapid-key
VAPID_PRIVATE_KEY=your-private-vapid-key

# Firebase (Optional - Native Apps)
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account"...}

# Render
PORT=10000
BASE_URL=https://pryde-backend.onrender.com
FRONTEND_URL=https://prydeapp.com
API_DOMAIN=https://api.prydeapp.com
ROOT_DOMAIN=prydeapp.com

# Email (Resend)
RESEND_API_KEY=re_123...

# R2 (Optional - Replace GridFS)
R2_ENABLED=true
R2_ACCOUNT_ID=...
R2_ACCESS_KEY_ID=...
R2_SECRET_ACCESS_KEY=...
R2_BUCKET_NAME=pryde-media
R2_PUBLIC_URL=https://media.prydeapp.com

# App
NODE_ENV=production

