# ============================================
# PRYDE SOCIAL - PRODUCTION ENVIRONMENT VARIABLES
# ============================================
# Copy this file to .env and fill in your values

# ============================================
# REDIS CONFIGURATION (REQUIRED IN PRODUCTION)
# ============================================

# Option 1: Use REDIS_URL (Render, Railway, Upstash, Redis Cloud, etc.)
REDIS_URL=rediss://username:password@host:port

# Option 2: Individual Redis connection details
# REDIS_HOST=your-redis-host.example.com
# REDIS_PORT=6379
# REDIS_PASSWORD=your_redis_password
# REDIS_TLS=true

# Optional Redis tuning
# REDIS_CONNECT_TIMEOUT=5000
# REDIS_MAX_RETRIES=3

# ============================================
# CLOUDFLARE R2 CDN (RECOMMENDED)
# ============================================

# Enable R2 storage for media files
R2_ENABLED=true

# R2 Account Dashboard > Overview > Account ID
R2_ACCOUNT_ID=your_r2_account_id

# R2 > Settings > API Tokens > Create API Token
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key

# R2 > Buckets > Create Bucket (name it something like 'pryde-social-media')
R2_BUCKET_NAME=pryde-social-media

# Custom domain for CDN (Cloudflare > R2 > Custom Domains)
# Must match the domain you set up in Cloudflare
R2_PUBLIC_URL=https://media.prydeapp.com

# ============================================
# EXISTING VARIABLES (ALREADY CONFIGURED)
# ============================================

# MongoDB
# MONGODB_URI=mongodb+srv://...

# JWT
# JWT_SECRET=your_jwt_secret
# JWT_REFRESH_SECRET=your_refresh_secret

# Firebase (for push notifications)
# FIREBASE_PROJECT_ID=...
# FIREBASE_PRIVATE_KEY=...
# FIREBASE_CLIENT_EMAIL=...

# Cloudflare (forturnstile)
# TURNSTILE_SITE_KEY=...
# TURNSTILE_SECRET_KEY=...
